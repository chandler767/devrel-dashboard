# ── YouTube ────────────────────────────────────────────────────────────────
# Your channel handle (with or without the @).
# Only YouTube Shorts are fetched. Add long-form videos to manual_videos.json.
# Requires: brew install yt-dlp

YOUTUBE_HANDLE=

# ── TikTok ─────────────────────────────────────────────────────────────────
# Your TikTok username (without the @).
# Requires: brew install yt-dlp

TIKTOK_USERNAME=

# ── LinkedIn ───────────────────────────────────────────────────────────────
# Cookie auth — no developer app needed.
#
# How to get these values (Safari or Chrome):
#   1. Log into linkedin.com
#   2. Open DevTools → Storage → Cookies → https://www.linkedin.com
#   3. Copy the values for each cookie listed below
#
# Required:
LINKEDIN_LI_AT=
LINKEDIN_JSESSIONID=
#
# Required for feed access (LinkedIn rejects requests without these):
#   bcookie  — looks like:  "v=2&xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
#   bscookie — looks like:  "v=1&20250101000000&abc123..."
LINKEDIN_BCOOKIE=
LINKEDIN_BSCOOKIE=

# Optional: your profile URL slug (the part after linkedin.com/in/).
# Leave blank to auto-detect from your session.
LINKEDIN_PUBLIC_ID=

# Optional: LinkedIn Pages you manage (comma-separated organization URNs).
# Find your org ID from the admin URL: linkedin.com/company/12345678/admin/
# The URN format is: urn:li:organization:12345678
LINKEDIN_ORG_URNS=
